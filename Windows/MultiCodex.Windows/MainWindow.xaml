<Window x:Class="MultiCodex.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MultiCodex for Windows" Height="650" Width="900" MinHeight="520" MinWidth="720"
        WindowStartupLocation="CenterScreen" Background="#0B1020" Foreground="White">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <DockPanel>
            <StackPanel>
                <TextBlock Text="MultiCodex" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Multiple Codex accounts, in-app device login, one Windows tray app" Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
            <Border DockPanel.Dock="Right" Background="{StaticResource PanelBrush}" CornerRadius="12" Padding="14,8">
                <TextBlock x:Name="RuntimeText" Text="Checking Codex..."/>
            </Border>
        </DockPanel>

        <WrapPanel Grid.Row="1" Margin="-4,18,-4,14">
            <Button x:Name="RefreshButton" Content="Refresh usage" Click="Refresh_Click"
                    ToolTip="Reload saved accounts and usage limits"/>
            <Button x:Name="LoginButton" Content="Log in account" Click="Login_Click"
                    ToolTip="Create or relogin an account in an isolated Codex home"/>
            <Button x:Name="ImportButton" Content="Import current login" Click="Add_Click"
                    ToolTip="Save the currently active ~/.codex/auth.json as an account"/>
            <Button x:Name="SwitchButton" Content="Switch selected" Click="Switch_Click" IsEnabled="False"
                    ToolTip="Copy the selected account auth into ~/.codex/auth.json"/>
            <Button x:Name="RemoveButton" Content="Remove selected" Click="Remove_Click" IsEnabled="False"
                    ToolTip="Remove the selected account from MultiCodex"/>
            <Button Content="Open data folder" Click="OpenFolder_Click"/>
        </WrapPanel>

        <DataGrid x:Name="AccountsGrid" Grid.Row="2" ItemsSource="{Binding Accounts}" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  Background="#101624" Foreground="White" RowBackground="#101624" AlternatingRowBackground="#151B27"
                  BorderBrush="#263247" RowHeight="48" SelectionChanged="AccountsGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Account" Binding="{Binding Name}" Width="2*" ElementStyle="{StaticResource GridTextCellStyle}"/>
                <DataGridTextColumn Header="" Binding="{Binding CurrentLabel}" Width="90" ElementStyle="{StaticResource GridTextCellStyle}"/>
                <DataGridTextColumn Header="Auth" Binding="{Binding AuthLabel}" Width="120" ElementStyle="{StaticResource GridTextCellStyle}"/>
                <DataGridTextColumn Header="5 hour" Binding="{Binding FiveHour}" Width="90" ElementStyle="{StaticResource GridTextCellStyle}"/>
                <DataGridTextColumn Header="Weekly" Binding="{Binding Weekly}" Width="90" ElementStyle="{StaticResource GridTextCellStyle}"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="2*" ElementStyle="{StaticResource GridTextCellStyle}"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="FooterText" Grid.Row="3" Margin="0,14,0,0" Foreground="{StaticResource MutedBrush}"
                   Text="First run: install Codex CLI, click Log in account, then choose Device Code or Normal browser login."/>
    </Grid>
</Window>
