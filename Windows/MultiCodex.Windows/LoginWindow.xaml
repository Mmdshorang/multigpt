<Window x:Class="MultiCodex.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex login" Height="650" Width="780" MinHeight="580" MinWidth="650"
        WindowStartupLocation="CenterOwner" Background="#0B1020" Foreground="White">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="TitleText" Text="Sign in to Codex" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="No terminal is required. MultiCodex runs the Codex login process here."
                       Margin="0,5,0,0" Foreground="{StaticResource MutedBrush}"/>
        </StackPanel>

        <StackPanel x:Name="MethodPanel" Grid.Row="1" Margin="0,16,0,12">
            <TextBlock Text="Choose a sign-in method" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="DeviceCodeButton" Grid.Column="0" Margin="0,0,6,0" Padding="14,12"
                        Click="DeviceCode_Click" ToolTip="Recommended when localhost callback is blocked">
                    <StackPanel>
                        <TextBlock Text="Device code (recommended)" FontWeight="Bold"/>
                        <TextBlock Text="Copy a one-time code into the browser" Margin="0,3,0,0"
                                   FontWeight="Normal" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BrowserCallbackButton" Grid.Column="1" Margin="6,0,0,0" Padding="14,12"
                        Click="BrowserCallback_Click" ToolTip="Uses the local callback on port 1455">
                    <StackPanel>
                        <TextBlock Text="Normal browser login" FontWeight="Bold"/>
                        <TextBlock Text="No device code; uses localhost callback" Margin="0,3,0,0"
                                   FontWeight="Normal" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>

        <Border Grid.Row="2" Margin="0,0,0,12" Padding="12" CornerRadius="8"
                Background="#10243A" BorderBrush="#245170" BorderThickness="1">
            <TextBlock x:Name="MethodHelpText" TextWrapping="Wrap"
                       Text="Device Code is recommended on Windows. Normal login is also available when local callback port 1455 is free."/>
        </Border>

        <Grid x:Name="DeviceCodePanel" Grid.Row="3" Margin="0,0,0,12" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="CodeDisplayBorder" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="One-time code: " Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock x:Name="CodeText" Text="waiting..." FontFamily="Consolas" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Button x:Name="CopyCodeButton" Grid.Column="1" Content="Copy code" Click="CopyCode_Click" IsEnabled="False"/>
            <Button x:Name="OpenPageButton" Grid.Column="2" Content="Open sign-in page" Click="OpenPage_Click" IsEnabled="False"/>
        </Grid>

        <TextBox x:Name="OutputBox" Grid.Row="4" IsReadOnly="True" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="13" TextWrapping="NoWrap"/>

        <Grid Grid.Row="5" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"
                       Text="Choose a sign-in method." TextWrapping="Wrap" Margin="0,0,12,0"/>
            <Button x:Name="CancelButton" Grid.Column="1" Content="Cancel" Click="Cancel_Click"/>
            <Button x:Name="CloseButton" Grid.Column="2" Content="Close" Click="Close_Click" IsEnabled="False"/>
        </Grid>
    </Grid>
</Window>
