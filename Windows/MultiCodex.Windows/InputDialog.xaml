<Window x:Class="MultiCodex.Windows.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account name" Height="165" Width="410" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="#0B1020" Foreground="White">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
        <TextBlock Text="Choose a name for the current Codex login" Margin="0,0,0,8"/>
        <TextBox x:Name="ValueBox" Grid.Row="1" Height="30" VerticalContentAlignment="Center"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" IsCancel="True"/>
            <Button Content="Add account" IsDefault="True" Click="Accept_Click"/>
        </StackPanel>
    </Grid>
</Window>
